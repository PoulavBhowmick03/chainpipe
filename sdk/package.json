{
  "name": "@ishitaaaaw/x402-solana",
  "version": "0.1.0",
  "description": "TypeScript SDK for the LedgerForge x402 payment rail on Solana — discover, pay for, and execute on-chain agent skills.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "x402",
    "solana",
    "anchor",
    "agent",
    "payments",
    "stablecoin",
    "spl-token"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PoulavBhowmick03/ledgerforge",
    "directory": "sdk"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.8",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.22.3",
    "typescript": "^5.3.3"
  }
}
